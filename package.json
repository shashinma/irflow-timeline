{
  "name": "irflow-timeline",
  "version": "1.0.5",
  "description": "IRFlow Timeline — High-performance DFIR timeline viewer for macOS (30-50GB+ CSV/XLSX)",
  "main": "electron/main.js",
  "author": "DFIR Community",
  "license": "Apache-2.0",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build:renderer": "vite build",
    "start": "npm run build:renderer && electron .",
    "dist": "npm run build:renderer && electron-builder --config electron-builder.config.cjs --mac",
    "dist:release": "npm run dist",
    "dist:smoke": "npm run build:renderer && SKIP_NOTARIZE=1 CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --config electron-builder.config.cjs --mac",
    "dist:dmg": "npm run build:renderer && electron-builder --config electron-builder.config.cjs --mac dmg",
    "dist:universal": "npm run build:renderer && electron-builder --config electron-builder.config.cjs --mac --universal",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "postinstall": "patch-package",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "devDependencies": {
    "@electron/notarize": "^3.1.1",
    "@electron/rebuild": "^3.6.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "patch-package": "^8.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^6.0.7",
    "vitepress": "^1.6.4",
    "wait-on": "^8.0.1"
  },
  "dependencies": {
    "@ts-evtx/core": "^1.1.1",
    "@ts-evtx/messages": "^1.1.1",
    "better-sqlite3": "^11.7.0",
    "csv-parser": "^3.0.0",
    "electron-updater": "^6.6.7",
    "exceljs": "^4.4.0",
    "xlsx": "^0.18.5"
  }
}
